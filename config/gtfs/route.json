    },
    {
      "trip_headsign_regex": "not in service",
      "ignore_case": true
    }
  ],
  "trip_headsign_cleaners": [
    {
      "regex": "^[a-z]+[\\d]+[a-z]?$",
      "ignore_case": true
    },
    {
      "regex": "^\\d+ (eastbound|westbound|northbound|southbound|e|w|n|s)",
      "ignore_case": true,
      "replacement": "$1"
    },
    {
      "regex": "((?<=(^|\\W))(transit windsor terminal|transit windsor term|transit terminal|transit term)(?=(\\W|$)))",
      "ignore_case": true,
      "replacement": "Windsor Transit Terminal"
    },
    {
      "is_word": true,
      "regex": "hotel dieu grace healthcare",
      "replacement": "HDGH"
    },
    {
      "is_word": true,
      "regex": "rear entrance"
    },
    {
      "is_word": true,
      "regex": "front entrance"
    }
  ],
